# ============================================================
# AtomClaw — Ortam Değişkenleri
# Bu dosyayı .env olarak kopyalayın: cp .env.example .env
# ============================================================

# -----------------------------------------------------------
# TEMEL AYARLAR
# -----------------------------------------------------------

# Bot'un adı (WhatsApp trigger için kullanılır: @Atom)
ASSISTANT_NAME=Atom

# Kullanılacak AI sağlayıcısı: kilocode | ollama
PROVIDER=kilocode

# -----------------------------------------------------------
# KİLOCODE AYARLARI (PROVIDER=kilocode ise gerekli)
# -----------------------------------------------------------

# Kilocode API token'ı (kilocode.dev'den alın)
# Token yoksa `npm run auth` ile cihaz kimlik doğrulaması yapabilirsiniz
KILOCODE_TOKEN=

# Kullanılacak model (varsayılan: kilo-auto-free)
# Örnekler: kilo-auto-free, openai/gpt-4o, anthropic/claude-3-5-sonnet
KILOCODE_MODEL=kilo-auto-free

# -----------------------------------------------------------
# OLLAMA AYARLARI (PROVIDER=ollama ise gerekli)
# -----------------------------------------------------------

# Ollama sunucu adresi
OLLAMA_BASE_URL=http://localhost:11434

# Kullanılacak model
OLLAMA_MODEL=llama3

# -----------------------------------------------------------
# WHATSAPP AYARLARI
# -----------------------------------------------------------

# WhatsApp kanalını etkinleştir
WHATSAPP_ENABLED=true

# Bot'un kendi numarasına sahip olup olmadığı (dedicated numara = true)
ASSISTANT_HAS_OWN_NUMBER=false

# -----------------------------------------------------------
# GRUP KAYIT (İLK KURULUM)
# -----------------------------------------------------------

# İlk kurulumda bu JID'i otomatik ana grup olarak kaydet.
# WhatsApp DM için: <numara>@s.whatsapp.net (örn: 905551234567@s.whatsapp.net)
# WhatsApp grup için: <grup_id>@g.us
# Bir kez kayıt olduktan sonra bu değeri boş bırakabilirsiniz.
AUTO_REGISTER_MAIN_JID=

# -----------------------------------------------------------
# ZAMAN DİLİMİ
# -----------------------------------------------------------

# IANA timezone (https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TZ=Europe/Istanbul
